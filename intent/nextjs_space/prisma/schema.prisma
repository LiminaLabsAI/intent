generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output   = "../node_modules/.prisma/client"
    previewFeatures = ["postgresqlExtensions"]
}

datasource db {
    provider   = "postgresql"
    url        = env("DATABASE_URL")
    extensions = [vector]
}

enum UserRole {
  ADMIN
  REVIEWER
  END_USER
}

enum IntentStatus {
  DRAFT
  IN_PROGRESS
  NEEDS_CLARIFICATION
  UNDER_REVIEW
  APPROVED
  CONDITIONAL_APPROVAL
  REJECTED
  ARCHIVED
  DISPATCHED
  EXECUTED
}

enum IntentType {
  CHANGE
  CREATE
  ANALYZE
  REPORT
  DELETE
  UPDATE
  OTHER
}

enum DecisionOutcome {
  AUTO_APPROVED
  NEEDS_CLARIFICATION
  HUMAN_REVIEW_REQUIRED
  CONDITIONAL_APPROVAL
  REJECTED
}

enum ReviewDecision {
  APPROVE
  REJECT
  REQUEST_CHANGES
  ESCALATE
}

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String?      @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           UserRole     @default(END_USER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  apiKey         String?      @unique
  intents        Intent[]     @relation("IntentRequester")
  reviewTasks    ReviewTask[] @relation("ReviewAssignee")
  comments       Comment[]
  auditLogs      AuditLog[]
  accounts       Account[]
  sessions       Session[]

  @@index([email])
  @@index([role])
}

model Intent {
  id                  String          @id @default(cuid())
  intentId            String?         @unique
  version             Int             @default(1)
  rawInput            String
  status              IntentStatus    @default(DRAFT)
  
  // Stage 2: Parsed
  entities            Json?           
  actions             Json?           
  scope               String?         
  businessDomain      String?         
  initialContext      String?         
  
  // Stage 3: Semantic Understanding
  businessObjective   String?         
  intentType          IntentType?     
  affectedAssets      Json?           
  confidenceScore     Float?          
  
  // Stage 4: Normalization
  standardizedIntent  String?         
  ontologyMappings    Json?           
  domainAlignment     String?         
  normalizedScope     String?         
  
  // Stage 5: Quality Gate
  completenessScore   Float?          
  clarityScore        Float?          
  consistencyScore    Float?          
  qualityGateResult   String?         
  qualityGateDetails  Json?           
  
  // Stage 6: Approval Decision
  decisionOutcome     DecisionOutcome?
  evidenceQuality     Float?          
  policyCompliance    Boolean?        
  riskLevel           String?         
  delegationPolicy    String?         
  autonomyEligible    Boolean?        
  decisionDetails     Json?           
  
  // Stage 7: Intent ID
  approvedAt          DateTime?       
  linkedEvidence      Json?           
  
  // Metadata
  priority            String?         @default("MEDIUM")
  expectedOutcome     String?         
  currentStage        Int             @default(1)
  processingLog       Json?           
  artifacts           Json?
  transcript          Json?           // the /refine chat history (ChatTurn[]) — FEAT-001           
  
  // Relations
  requesterId         String
  requester           User            @relation("IntentRequester", fields: [requesterId], references: [id])
  parentIntentId      String?
  parentIntent        Intent?         @relation("SubIntents", fields: [parentIntentId], references: [id])
  subIntents          Intent[]        @relation("SubIntents")
  clarifyingQuestions Json?          
  clarifyingAnswers   Json?          
  versions            IntentVersion[]
  reviewTasks         ReviewTask[]
  comments            Comment[]
  auditLogs           AuditLog[]
  
  // Knowledge Graph Relations
  topics              TopicToIntent[]
  contexts            ContextToIntent[]
  
  // Vector Embedding
  embedding           Unsupported("vector(1536)")?
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  
  @@index([status])
  @@index([requesterId])
  @@index([createdAt])
  @@index([intentType])
}

model IntentVersion {
  id              String   @id @default(cuid())
  intentId        String
  intent          Intent   @relation(fields: [intentId], references: [id])
  version         Int
  snapshot        Json
  changedBy       String
  changeReason    String?
  createdAt       DateTime @default(now())

  @@index([intentId])
}

model ReviewTask {
  id              String         @id @default(cuid())
  intentId        String
  intent          Intent         @relation(fields: [intentId], references: [id])
  assigneeId      String?
  assignee        User?          @relation("ReviewAssignee", fields: [assigneeId], references: [id])
  decision        ReviewDecision?
  reason          String?
  conditions      String?
  slaDeadline     DateTime?
  completedAt     DateTime?
  context         Json?
  evidence        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([intentId])
  @@index([assigneeId])
}

model Comment {
  id          String   @id @default(cuid())
  intentId    String
  intent      Intent   @relation(fields: [intentId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  createdAt   DateTime @default(now())

  @@index([intentId])
}

model AuditLog {
  id          String   @id @default(cuid())
  intentId    String?
  intent      Intent?  @relation(fields: [intentId], references: [id])
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  details     Json?
  stage       Int?
  createdAt   DateTime @default(now())

  @@index([intentId])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default("default")
  provider  String   @default("abacusai") // "abacusai" | "huggingface" | "ollama"
  apiKey    String?  
  endpoint  String?  
  modelId   String?  
  updatedAt DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Knowledge Graph Nodes and Edges

model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  intents     TopicToIntent[]
  createdAt   DateTime @default(now())
}

model TopicToIntent {
  topicId   String
  intentId  String
  topic     Topic  @relation(fields: [topicId], references: [id])
  intent    Intent @relation(fields: [intentId], references: [id])
  relevance Float?
  
  @@id([topicId, intentId])
}

model ContextNode {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String   // e.g., "TEAM", "SYSTEM", "BUSINESS_PROCESS"
  intents     ContextToIntent[]
  createdAt   DateTime @default(now())
}

model ContextToIntent {
  contextId String
  intentId  String
  context   ContextNode @relation(fields: [contextId], references: [id])
  intent    Intent      @relation(fields: [intentId], references: [id])
  relation  String?     // e.g., "AFFECTS", "BELONGS_TO"

  @@id([contextId, intentId])
}

// ── Phase 7: Deterministic Trunk — event-sourced record (additive) ────────────
// The append-only IntentEvent log is the source of truth; SlotValue is a
// materialized projection for fast reads. Kept standalone (intentId as a plain
// string, no FK) so the legacy Intent row + pipeline are entirely untouched.

model IntentEvent {
  id        String   @id @default(cuid())
  intentId  String
  seq       Int      // monotonic ordering within an intent
  kind      String   // created | classified | slot_added | slot_valued | slot_assessed | transitioned
  payload   Json     // the event body (matches lib/agent IntentEvent)
  actor     String   // user | agent id
  createdAt DateTime @default(now())

  @@unique([intentId, seq])
  @@index([intentId])
}

model SlotValue {
  id        String   @id @default(cuid())
  intentId  String
  key       String
  value     String?
  state     String   // empty | weak | ambiguous | conflicting | strong
  reason    String?
  evidence  Json?
  updatedAt DateTime @updatedAt

  @@unique([intentId, key])
  @@index([intentId])
}

// ── Cost config (ADR-0001) — the volatile, model/provider-dependent variables as DATA ─
model CostModel {
  id                  String   @id // stable id, e.g. 'deepseek-v4-flash'
  name                String
  provider            String
  priceIn             Float // USD per 1M input tokens
  priceOut            Float // USD per 1M output tokens
  contextWindow       Int
  maxOutput           Int
  tokenizerId         String   @default("approx")
  cacheDiscount       Float    @default(0)
  reasoningMultiplier Float    @default(1)
  sourceNote          String?
  updatedAt           DateTime @updatedAt
}

model Persona {
  id             String   @id // 'fast' | 'balanced' | 'thorough'
  name           String
  modelRef       String // → CostModel.id
  temperature    Float
  reasoningDepth String // low | medium | high
  promptStyle    String // terse | standard | verbose
  retrieval      String   @default("none") // none | rag
  budgetCeiling  Float?
  visibleToUser  Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@index([modelRef])
}

model EstimationPrior {
  refClass   String   @id // 'code:moderate'
  outLow     Int
  outHigh    Int
  sampleSize Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// Estimated-vs-actual output tokens — accumulates now so calibration (Phase 18) has a corpus.
model CostObservation {
  id        String   @id @default(cuid())
  intentId  String?
  refClass  String
  personaId String?
  estOutLow Int
  estOutHigh Int
  actualOut Int
  createdAt DateTime @default(now())

  @@index([refClass])
}
